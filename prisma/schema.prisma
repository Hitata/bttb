generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  readings      BaziReading[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model BaziReading {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  gender      String
  birthYear   Int
  birthMonth  Int
  birthDay    Int
  birthHour   Int?
  birthMinute Int?
  result      String   // JSON BaziResult
  slug        String?  @unique
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model BaziCase {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  birthDate   String
  birthTime   String?
  gender      String
  location    String?
  description String?
  categories  String    // JSON string[]
  tags        String    // JSON string[]
  chartData   String    // JSON BaziResult
  coreAnalysis String?
  traits      String    // JSON TraitItem[]
  timeline    String    // JSON TimelineEvent[]
  luckPillars String
  faq         String
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model IChingReading {
  id             String   @id @default(cuid())
  imageHash      String
  question       String   @default("")
  intentionTime  DateTime
  lines          String   // JSON array [6,7,8,9,...]
  coins          String   // JSON array of coin throws
  primaryNumber  Int
  changedNumber  Int?
  nuclearNumber  Int
  prompt         String   // the generated text prompt
  analysisMode   String   @default("standard") // deep | standard | simple
  createdAt      DateTime @default(now())

  @@index([imageHash])
  @@index([createdAt])
}

model BaziClient {
  id            String   @id @default(cuid())
  name          String
  gender        String   // "male" | "female"
  birthYear     Int
  birthMonth    Int
  birthDay      Int
  birthHour     Int      @default(0)
  birthMinute   Int      @default(0)
  dayMaster     String   // e.g. "Đinh Hỏa" — Day Master stem + element
  chartSummary  String   // Short text summary of the chart for display
  fullChart     String   // JSON BaziResult
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([name])
}

model Hexagram {
  number        Int     @id
  nameVi        String
  nameZh        String
  nameEn        String
  structure     String
  nuclearNumber Int
  energyState   String
  physicist     String
  sage          String
  advisor       String
  balance       String
}
