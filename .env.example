# Supabase Database
SUPABASE_DB_HOST="your-project.pooler.supabase.com"
SUPABASE_DB_HOST_DIRECT="db.your-project.supabase.co"
SUPABASE_DB_USER="postgres.your-project"
SUPABASE_DB_USER_DIRECT="postgres"
SUPABASE_DB_PASSWORD="your-supabase-db-password"
SUPABASE_DB_NAME="postgres"
SUPABASE_DB_PORT="6543"
SUPABASE_DB_PORT_DIRECT="5432"

# Auth
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Admin
ADMIN_JWT_SECRET="generate-with-openssl-rand-base64-32"
