# Database (Supabase PostgreSQL)
# Pooler URL for runtime queries (port 6543, pgbouncer)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct URL for migrations (port 5432)
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# Auth
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Admin
ADMIN_JWT_SECRET="generate-with-openssl-rand-base64-32"
